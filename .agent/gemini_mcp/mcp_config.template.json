{
  "mcpServers": {
    "google-gemini": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-google-generative-ai"
      ],
      "env": {
        "GOOGLE_GENAI_API_KEY": "${GOOGLE_GENAI_API_KEY}"
      }
    },
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp",
        "--api-key",
        "${CONTEXT7_API_KEY}"
      ]
    },
    "shadcn": {
      "command": "npx",
      "args": [
        "shadcn@latest",
        "mcp"
      ]
    }
  }
}
